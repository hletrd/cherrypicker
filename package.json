{
  "name": "cherrypicker",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "cd apps/web && node --run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:bun": "bun test packages/parser tools/scraper",
    "test:e2e": "turbo run build --filter=@cherrypicker/core --filter=@cherrypicker/rules --filter=@cherrypicker/web && playwright test",
    "lint": "npm run --workspaces --if-present --include-workspace-root=false lint",
    "typecheck": "npm run --workspaces --if-present --include-workspace-root=false typecheck",
    "verify": "npm run lint && npm run typecheck && bun run test",
    "parse": "bun run packages/parser/src/index.ts",
    "scrape": "bun run tools/scraper/src/cli.ts",
    "analyze": "bun run tools/cli/src/index.ts analyze",
    "optimize": "bun run tools/cli/src/index.ts optimize"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "packageManager": "bun@1.2.6"
}
