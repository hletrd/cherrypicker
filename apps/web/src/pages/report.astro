---
import Layout from '../layouts/Layout.astro';
---

<Layout title="리포트">
  <div class="print:p-0">
    <!-- Toolbar (hidden on print) -->
    <div class="mb-6 flex items-center justify-between print:hidden">
      <div>
        <a
          href={`${import.meta.env.BASE_URL}results`}
          class="mb-2 inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-primary)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
          </svg>
          결과로 돌아가기
        </a>
        <h1 class="text-2xl font-bold">분석 리포트</h1>
      </div>
      <div class="flex gap-3">
        <button
          onclick="window.print()"
          class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-primary)] px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-[var(--color-primary-dark)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m0 0a48.103 48.103 0 0 1 10.5 0m-10.5 0V6.312c0-.777.529-1.462 1.296-1.565A48.566 48.566 0 0 1 12 4.558c1.646 0 3.278.119 4.874.35.767.103 1.296.788 1.296 1.565V7.034"/>
          </svg>
          인쇄 / PDF 저장
        </button>
      </div>
    </div>

    <!-- Report content -->
    <div
      id="report-content"
      class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-8 shadow-[var(--shadow-card)] print:rounded-none print:border-0 print:p-0 print:shadow-none"
    >
      <div class="flex flex-col items-center gap-4 py-8">
        <p class="text-[var(--color-text-muted)]">아직 분석 결과가 없어요</p>
        <a href={import.meta.env.BASE_URL}
          class="inline-flex items-center gap-1 rounded-lg bg-[var(--color-primary)] px-5 py-2.5 text-sm font-medium text-white hover:bg-[var(--color-primary-dark)] transition-colors"
        >명세서 올리러 가기</a>
      </div>
    </div>
  </div>
</Layout>

<script>
  try {
    function esc(s: unknown) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    const raw = sessionStorage.getItem('cherrypicker:analysis');
    if (raw) {
      const data = JSON.parse(raw);
      const opt = data.optimization;
      if (opt) {
        const fmt = (n: number) => n.toLocaleString('ko-KR') + '원';
        const el = document.getElementById('report-content');
        if (el) {
          const uniqueCards = new Set(opt.assignments.map((a: { assignedCardId: string }) => a.assignedCardId)).size;
          let html = '<h2 style="font-size:1.25rem;font-weight:bold;margin-bottom:1rem;">분석 요약</h2>';
          html += '<table style="width:100%;border-collapse:collapse;margin-bottom:2rem;">';
          html += '<tr><td style="padding:8px;border-bottom:1px solid #e2e8f0;">분석 기간</td><td style="padding:8px;border-bottom:1px solid #e2e8f0;">' + (data.statementPeriod ? esc(data.statementPeriod.start) + ' ~ ' + esc(data.statementPeriod.end) : '-') + '</td></tr>';
          html += '<tr><td style="padding:8px;border-bottom:1px solid #e2e8f0;">총 지출</td><td style="padding:8px;border-bottom:1px solid #e2e8f0;">' + fmt(opt.totalSpending) + '</td></tr>';
          html += '<tr><td style="padding:8px;border-bottom:1px solid #e2e8f0;">체리피킹 혜택</td><td style="padding:8px;border-bottom:1px solid #e2e8f0;">' + fmt(opt.totalReward) + '</td></tr>';
          html += '<tr><td style="padding:8px;border-bottom:1px solid #e2e8f0;">추가 절약</td><td style="padding:8px;border-bottom:1px solid #e2e8f0;">+' + fmt(opt.savingsVsSingleCard) + '</td></tr>';
          html += '<tr><td style="padding:8px;">필요 카드 수</td><td style="padding:8px;">' + uniqueCards + '장</td></tr>';
          html += '</table>';
          html += '<h2 style="font-size:1.25rem;font-weight:bold;margin-bottom:1rem;">카테고리별 추천 카드</h2>';
          html += '<table style="width:100%;border-collapse:collapse;">';
          html += '<thead><tr style="border-bottom:2px solid #e2e8f0;"><th style="padding:8px;text-align:left;">카테고리</th><th style="padding:8px;text-align:left;">추천 카드</th><th style="padding:8px;text-align:right;">혜택률</th><th style="padding:8px;text-align:right;">월 혜택</th></tr></thead><tbody>';
          for (const a of opt.assignments) {
            html += '<tr style="border-bottom:1px solid #e2e8f0;">';
            html += '<td style="padding:8px;">' + esc(a.categoryNameKo) + '</td>';
            html += '<td style="padding:8px;">' + esc(a.assignedCardName) + '</td>';
            html += '<td style="padding:8px;text-align:right;">' + (a.rate * 100).toFixed(1) + '%</td>';
            html += '<td style="padding:8px;text-align:right;">' + fmt(a.reward) + '</td>';
            html += '</tr>';
          }
          html += '</tbody></table>';
          el.innerHTML = html;
        }
      }
    }
  } catch {}
</script>

<style>
  @media print {
    :global(nav),
    :global(footer) {
      display: none !important;
    }
    :global(main) {
      padding: 0 !important;
    }
    :global(body) {
      background: #fff !important;
      color: #000 !important;
    }
    #report-content {
      border: none !important;
      box-shadow: none !important;
      padding: 0 !important;
    }
  }
</style>
