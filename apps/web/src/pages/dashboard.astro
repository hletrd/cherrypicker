---
import Layout from '../layouts/Layout.astro';
import SpendingSummary from '../components/dashboard/SpendingSummary.svelte';
import CategoryBreakdown from '../components/dashboard/CategoryBreakdown.svelte';
import OptimalCardMap from '../components/dashboard/OptimalCardMap.svelte';
import SavingsComparison from '../components/dashboard/SavingsComparison.svelte';
import TransactionReview from '../components/dashboard/TransactionReview.svelte';
---

<Layout title="대시보드">
  <!-- Back link -->
  <div class="mb-6">
    <a
      href={`${import.meta.env.BASE_URL}`}
      class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-primary)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
      </svg>
      명세서 업로드로 돌아가기
    </a>
  </div>

  <!-- Page header -->
  <div class="mb-8 animate-[slideUp_0.4s_ease_both]">
    <h1 class="text-3xl font-extrabold tracking-tight">내 지출 분석</h1>
    <p class="mt-2 text-[var(--color-text-muted)]">분석이 끝났어요</p>
  </div>

  <!-- Top row: summary + breakdown -->
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div
      class="card-transition rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-card)] animate-[slideUp_0.4s_0.05s_ease_both]"
      style="opacity:0;animation-fill-mode:forwards;"
    >
      <h2 class="mb-4 flex items-center gap-2 text-lg font-semibold">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20" class="text-[var(--color-primary)]" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>
        </svg>
        지출 요약
      </h2>
      <SpendingSummary client:load />
    </div>

    <div
      class="card-transition rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-card)] animate-[slideUp_0.4s_0.1s_ease_both]"
      style="opacity:0;animation-fill-mode:forwards;"
    >
      <h2 class="mb-4 flex items-center gap-2 text-lg font-semibold">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20" class="text-[var(--color-primary)]" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z"/>
        </svg>
        항목별 지출
      </h2>
      <CategoryBreakdown client:load />
    </div>

    <!-- Savings comparison: full width -->
    <div
      class="col-span-full card-transition rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-card)] animate-[slideUp_0.4s_0.15s_ease_both]"
      style="opacity:0;animation-fill-mode:forwards;"
    >
      <h2 class="mb-4 flex items-center gap-2 text-lg font-semibold">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20" class="text-[var(--color-primary)]" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/>
        </svg>
        절약 비교
      </h2>
      <SavingsComparison client:load />
    </div>

    <!-- Transaction review -->
    <div class="col-span-full">
      <TransactionReview client:load />
    </div>

    <!-- Optimal card map: full width -->
    <div
      class="col-span-full card-transition rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-card)] animate-[slideUp_0.4s_0.2s_ease_both]"
      style="opacity:0;animation-fill-mode:forwards;"
    >
      <h2 class="mb-4 flex items-center gap-2 text-lg font-semibold">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20" class="text-[var(--color-primary)]" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-4.5A3.375 3.375 0 0 0 13.125 11h-.25A3.375 3.375 0 0 0 9.5 14.375v4.375m0-10.5h.008v.008H9.5V8.25Zm4.5 0h.008v.008H14V8.25ZM6 6a6 6 0 0 0 3 5.197V15h6v-3.803A6 6 0 0 0 18 6V4.5A1.5 1.5 0 0 0 16.5 3h-9A1.5 1.5 0 0 0 6 4.5V6Z"/>
        </svg>
        항목별 추천 카드
      </h2>
      <OptimalCardMap client:load />
    </div>
  </div>

  <div class="mt-8 text-center animate-[slideUp_0.4s_0.3s_ease_both]" style="opacity:0;animation-fill-mode:forwards;">
    <a
      href={`${import.meta.env.BASE_URL}results`}
      class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-primary)] px-8 py-3 text-sm font-semibold text-white shadow-sm hover:bg-[var(--color-primary-dark)] transition-colors"
    >
      추천 결과 보기
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
    </a>
  </div>
</Layout>
