---
import Layout from '../layouts/Layout.astro';
import SavingsComparison from '../components/dashboard/SavingsComparison.svelte';
---

<Layout title="최적화 결과">
  <h1 class="text-2xl font-bold">카드 최적화 결과</h1>
  <p class="mt-2 text-[var(--color-text-muted)]">체리피킹으로 절약할 수 있는 금액을 확인하세요</p>

  <div class="mt-8">
    <SavingsComparison client:load />
  </div>

  <div class="mt-8 flex gap-4">
    <a
      href="/report"
      class="rounded-lg bg-[var(--color-primary)] px-6 py-3 text-white hover:bg-[var(--color-primary-dark)]"
    >
      HTML 리포트 보기
    </a>
    <button
      id="download-report"
      class="rounded-lg border border-[var(--color-border)] px-6 py-3 hover:bg-gray-50"
    >
      리포트 다운로드
    </button>
  </div>
</Layout>
