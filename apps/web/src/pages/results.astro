---
import Layout from '../layouts/Layout.astro';
import SavingsComparison from '../components/dashboard/SavingsComparison.svelte';
import OptimalCardMap from '../components/dashboard/OptimalCardMap.svelte';
---

<Layout title="추천 결과">
  <!-- Back link -->
  <div class="mb-6">
    <a
      href={`${import.meta.env.BASE_URL}`}
      class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-primary)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
      </svg>
      다시 분석하기
    </a>
  </div>

  <!-- Page header -->
  <div class="mb-8 animate-[slideUp_0.4s_ease_both]">
    <h1 class="text-3xl font-extrabold tracking-tight">카드 추천 결과</h1>
    <p class="mt-2 text-[var(--color-text-muted)]">카드를 잘 골라 쓰면 이만큼 아낄 수 있어요</p>
  </div>

  <!-- Summary statistics -->
  <div
    class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-3 animate-[slideUp_0.4s_0.05s_ease_both]"
    style="opacity:0;animation-fill-mode:forwards;"
  >
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 text-center shadow-[var(--shadow-card)]">
      <p class="text-xs font-medium uppercase tracking-wide text-[var(--color-text-muted)]">총 지출</p>
      <p class="mt-2 text-2xl font-bold text-[var(--color-text)]" id="stat-total-spending">—</p>
    </div>
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 text-center shadow-[var(--shadow-card)]">
      <p class="text-xs font-medium uppercase tracking-wide text-[var(--color-text-muted)]">예상 절약액</p>
      <p class="mt-2 text-2xl font-bold text-[var(--color-success)]" id="stat-total-savings">—</p>
    </div>
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 text-center shadow-[var(--shadow-card)]">
      <p class="text-xs font-medium uppercase tracking-wide text-[var(--color-text-muted)]">필요한 카드</p>
      <p class="mt-2 text-2xl font-bold text-[var(--color-primary)]" id="stat-cards-needed">—</p>
    </div>
  </div>

  <!-- Savings comparison component -->
  <div
    class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-card)] animate-[slideUp_0.4s_0.1s_ease_both]"
    style="opacity:0;animation-fill-mode:forwards;"
  >
    <SavingsComparison client:load />
  </div>

  <!-- OptimalCardMap component -->
  <div
    class="mt-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-card)] animate-[slideUp_0.4s_0.15s_ease_both]"
    style="opacity:0;animation-fill-mode:forwards;"
  >
    <h2 class="mb-4 text-lg font-bold">항목별 추천 카드</h2>
    <OptimalCardMap client:load />
  </div>

  <script is:inline src="/cherrypicker/scripts/results.js"></script>

  <!-- Action buttons -->
  <div
    class="mt-8 flex flex-wrap gap-4 animate-[slideUp_0.4s_0.15s_ease_both]"
    style="opacity:0;animation-fill-mode:forwards;"
  >
    <a
      href={`${import.meta.env.BASE_URL}report`}
      class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-primary)] px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-[var(--color-primary-dark)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
      </svg>
      리포트 보기
    </a>
    <button
      id="download-report"
      class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-3 text-sm font-semibold text-[var(--color-text)] shadow-sm transition-colors hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m0 0a48.103 48.103 0 0 1 10.5 0m-10.5 0V6.312c0-.777.529-1.462 1.296-1.565A48.566 48.566 0 0 1 12 4.558c1.646 0 3.278.119 4.874.35.767.103 1.296.788 1.296 1.565V7.034"/>
      </svg>
      인쇄 / PDF 저장
    </button>
    <a
      href={`${import.meta.env.BASE_URL}`}
      class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-3 text-sm font-semibold text-[var(--color-text-muted)] shadow-sm transition-colors hover:text-[var(--color-primary)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182"/>
      </svg>
      다시 분석하기
    </a>
    <a
      href={`${import.meta.env.BASE_URL}dashboard`}
      class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-3 text-sm font-semibold text-[var(--color-text-muted)] shadow-sm transition-colors hover:text-[var(--color-primary)]"
    >
      분석 자세히 보기
    </a>
  </div>
</Layout>
