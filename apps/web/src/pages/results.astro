---
import Layout from '../layouts/Layout.astro';
import SavingsComparison from '../components/dashboard/SavingsComparison.svelte';
---

<Layout title="최적화 결과">
  <!-- Back link -->
  <div class="mb-6">
    <a
      href="/"
      class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-primary)]"
    >
      ← 다시 분석하기
    </a>
  </div>

  <!-- Page header -->
  <div class="mb-8 animate-[slideUp_0.4s_ease_both]">
    <h1 class="text-3xl font-extrabold tracking-tight">카드 최적화 결과</h1>
    <p class="mt-2 text-[var(--color-text-muted)]">체리피킹으로 절약할 수 있는 금액을 확인하세요</p>
  </div>

  <!-- Summary statistics -->
  <div
    class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-3 animate-[slideUp_0.4s_0.05s_ease_both]"
    style="opacity:0;animation-fill-mode:forwards;"
  >
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 text-center shadow-[var(--shadow-card)]">
      <p class="text-xs font-medium uppercase tracking-wide text-[var(--color-text-muted)]">총 지출</p>
      <p class="mt-2 text-2xl font-bold text-[var(--color-text)]" id="stat-total-spending">—</p>
    </div>
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 text-center shadow-[var(--shadow-card)]">
      <p class="text-xs font-medium uppercase tracking-wide text-[var(--color-text-muted)]">예상 절약액</p>
      <p class="mt-2 text-2xl font-bold text-[var(--color-success)]" id="stat-total-savings">—</p>
    </div>
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 text-center shadow-[var(--shadow-card)]">
      <p class="text-xs font-medium uppercase tracking-wide text-[var(--color-text-muted)]">필요 카드 수</p>
      <p class="mt-2 text-2xl font-bold text-[var(--color-primary)]" id="stat-cards-needed">—</p>
    </div>
  </div>

  <!-- Savings comparison component -->
  <div
    class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-card)] animate-[slideUp_0.4s_0.1s_ease_both]"
    style="opacity:0;animation-fill-mode:forwards;"
  >
    <SavingsComparison client:load />
  </div>

  <!-- Action buttons -->
  <div
    class="mt-8 flex flex-wrap gap-4 animate-[slideUp_0.4s_0.15s_ease_both]"
    style="opacity:0;animation-fill-mode:forwards;"
  >
    <a
      href="/report"
      class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-primary)] px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-[var(--color-primary-dark)]"
    >
      📄 HTML 리포트 보기
    </a>
    <button
      id="download-report"
      class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-3 text-sm font-semibold text-[var(--color-text)] shadow-sm transition-colors hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]"
    >
      ⬇️ 리포트 다운로드
    </button>
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-3 text-sm font-semibold text-[var(--color-text-muted)] shadow-sm transition-colors hover:text-[var(--color-primary)]"
    >
      🔄 다시 분석하기
    </a>
  </div>
</Layout>
