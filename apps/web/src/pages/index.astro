---
import Layout from '../layouts/Layout.astro';
import FileDropzone from '../components/upload/FileDropzone.svelte';
---

<Layout title="홈">
  <!-- Hero Section -->
  <div class="relative -mx-6 -mt-8 overflow-hidden px-6 py-20 text-center" style="background: var(--gradient-hero);">
    <div class="absolute inset-0 opacity-20" style="background: radial-gradient(ellipse at 30% 50%, #ffffff33 0%, transparent 60%), radial-gradient(ellipse at 70% 50%, #ffffff22 0%, transparent 60%);"></div>
    <div class="relative z-10 animate-[slideUp_0.6s_ease_both]">
      <div class="mb-4 text-6xl">🍒</div>
      <h1 class="text-5xl font-extrabold tracking-tight text-white drop-shadow-sm md:text-6xl">
        CherryPicker
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-white/85 leading-relaxed">
        카드 명세서를 업로드하면<br class="hidden sm:block" />
        카테고리별 최적 카드를 추천해 드립니다
      </p>
    </div>
  </div>

  <!-- Stats Bar -->
  <div class="mx-auto mt-0 max-w-2xl -mb-4">
    <div class="flex divide-x divide-[var(--color-border)] rounded-b-2xl border border-t-0 border-[var(--color-border)] bg-[var(--color-surface)] shadow-sm animate-[fadeIn_0.5s_0.2s_ease_both]" style="opacity:0;animation-fill-mode:forwards;">
      <div class="flex flex-1 flex-col items-center py-4">
        <span class="text-2xl font-bold text-[var(--color-primary)] animate-[countUp_0.5s_0.3s_ease_both]" style="opacity:0;animation-fill-mode:forwards;">172+</span>
        <span class="mt-0.5 text-xs text-[var(--color-text-muted)]">카드</span>
      </div>
      <div class="flex flex-1 flex-col items-center py-4">
        <span class="text-2xl font-bold text-[var(--color-primary)] animate-[countUp_0.5s_0.4s_ease_both]" style="opacity:0;animation-fill-mode:forwards;">18개</span>
        <span class="mt-0.5 text-xs text-[var(--color-text-muted)]">카드사</span>
      </div>
      <div class="flex flex-1 flex-col items-center py-4">
        <span class="text-2xl font-bold text-[var(--color-primary)] animate-[countUp_0.5s_0.5s_ease_both]" style="opacity:0;animation-fill-mode:forwards;">16개</span>
        <span class="mt-0.5 text-xs text-[var(--color-text-muted)]">카테고리</span>
      </div>
    </div>
  </div>

  <!-- Upload Card -->
  <div class="mx-auto mt-10 w-full max-w-2xl animate-[slideUp_0.5s_0.2s_ease_both]" style="opacity:0;animation-fill-mode:forwards;">
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-card)]">
      <h2 class="mb-4 text-center text-base font-semibold text-[var(--color-text-muted)]">명세서 업로드</h2>
      <FileDropzone client:load />
    </div>
  </div>

  <!-- How it works -->
  <div class="mx-auto mt-16 max-w-3xl text-center animate-[slideUp_0.5s_0.35s_ease_both]" style="opacity:0;animation-fill-mode:forwards;">
    <h2 class="text-xl font-bold">이렇게 사용하세요</h2>
    <div class="mt-8 flex flex-col items-center gap-0 sm:flex-row sm:items-start sm:gap-0">
      <!-- Step 1 -->
      <div class="flex flex-1 flex-col items-center px-4">
        <div class="flex h-14 w-14 items-center justify-center rounded-full text-2xl font-bold text-white shadow-md" style="background: var(--gradient-hero);">①</div>
        <h3 class="mt-3 font-semibold">명세서 업로드</h3>
        <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">CSV, Excel, PDF 형식의<br />카드 명세서를 올려주세요</p>
      </div>
      <!-- Arrow -->
      <div class="my-2 text-2xl text-[var(--color-border)] sm:my-0 sm:mt-4 sm:text-3xl select-none">→</div>
      <!-- Step 2 -->
      <div class="flex flex-1 flex-col items-center px-4">
        <div class="flex h-14 w-14 items-center justify-center rounded-full text-2xl font-bold text-white shadow-md" style="background: var(--gradient-hero);">②</div>
        <h3 class="mt-3 font-semibold">AI 자동 분석</h3>
        <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">지출을 카테고리별로 자동<br />분류하고 패턴을 분석합니다</p>
      </div>
      <!-- Arrow -->
      <div class="my-2 text-2xl text-[var(--color-border)] sm:my-0 sm:mt-4 sm:text-3xl select-none">→</div>
      <!-- Step 3 -->
      <div class="flex flex-1 flex-col items-center px-4">
        <div class="flex h-14 w-14 items-center justify-center rounded-full text-2xl font-bold text-white shadow-md" style="background: var(--gradient-hero);">③</div>
        <h3 class="mt-3 font-semibold">최적 카드 추천</h3>
        <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">카테고리별 최적 카드와<br />예상 절약 금액을 알려드립니다</p>
      </div>
    </div>
  </div>

  <!-- Feature Cards -->
  <div class="mx-auto mt-16 grid w-full max-w-4xl grid-cols-1 gap-6 sm:grid-cols-3 animate-[slideUp_0.5s_0.45s_ease_both]" style="opacity:0;animation-fill-mode:forwards;">
    <div class="card-transition rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 text-center shadow-[var(--shadow-card)]" style="background: linear-gradient(145deg, var(--color-surface) 80%, #dbeafe44);">
      <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-2xl text-3xl" style="background: linear-gradient(135deg, #dbeafe, #bfdbfe);">📊</div>
      <h3 class="font-semibold">지출 분석</h3>
      <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed">
        CSV, Excel, PDF 명세서를 자동으로 인식하고 카테고리별로 분류합니다
      </p>
    </div>
    <div class="card-transition rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 text-center shadow-[var(--shadow-card)]" style="background: linear-gradient(145deg, var(--color-surface) 80%, #fef9c344);">
      <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-2xl text-3xl" style="background: linear-gradient(135deg, #fef9c3, #fde68a);">🏆</div>
      <h3 class="font-semibold">최적 카드 추천</h3>
      <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed">
        전월실적, 할인한도를 고려하여 카테고리별 최적 카드를 찾아줍니다
      </p>
    </div>
    <div class="card-transition rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 text-center shadow-[var(--shadow-card)]" style="background: linear-gradient(145deg, var(--color-surface) 80%, #d1fae544);">
      <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-2xl text-3xl" style="background: linear-gradient(135deg, #d1fae5, #a7f3d0);">💰</div>
      <h3 class="font-semibold">절약 시뮬레이션</h3>
      <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed">
        체리피킹 전후 혜택을 비교하고 연간 절약 금액을 확인하세요
      </p>
    </div>
  </div>
</Layout>
