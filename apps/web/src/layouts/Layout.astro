---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '신용카드 혜택 최적화 도구' } = Astro.props;
const pathname = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

function isActive(href: string) {
  if (href === base) return pathname === base || pathname === base.replace(/\/$/, '');
  return pathname.startsWith(href);
}
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; worker-src 'self' blob:; connect-src 'self';" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} | CherryPicker</title>
    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme');
          if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-[var(--color-bg)] text-[var(--color-text)] transition-colors duration-200">
    <nav class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-surface)]/95 backdrop-blur-sm">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href={`${base}`} class="flex items-center gap-2 text-xl font-bold text-[var(--color-primary)] hover:opacity-80 transition-opacity">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z"/>
          </svg>
          CherryPicker
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-6 text-sm">
          <a
            href={`${base}`}
            class={`transition-colors hover:text-[var(--color-primary)] ${isActive(base) ? 'font-semibold text-[var(--color-primary)]' : 'text-[var(--color-text-muted)]'}`}
          >홈</a>
          <a
            href={`${base}dashboard`}
            class={`transition-colors hover:text-[var(--color-primary)] ${isActive(`${base}dashboard`) ? 'font-semibold text-[var(--color-primary)]' : 'text-[var(--color-text-muted)]'}`}
          >대시보드</a>
          <a
            href={`${base}cards`}
            class={`transition-colors hover:text-[var(--color-primary)] ${isActive(`${base}cards`) ? 'font-semibold text-[var(--color-primary)]' : 'text-[var(--color-text-muted)]'}`}
          >카드 목록</a>
          <a
            href={`${base}results`}
            class={`transition-colors hover:text-[var(--color-primary)] ${isActive(`${base}results`) ? 'font-semibold text-[var(--color-primary)]' : 'text-[var(--color-text-muted)]'}`}
          >최적화 결과</a>

          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            aria-label="테마 전환"
            class="ml-2 flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text-muted)] transition-colors hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]"
          >
            <svg id="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="hidden" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
            </svg>
            <svg id="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="hidden" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/>
            </svg>
          </button>
        </div>

        <!-- Mobile controls -->
        <div class="flex items-center gap-2 md:hidden">
          <button
            id="theme-toggle-mobile"
            aria-label="테마 전환"
            class="flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text-muted)]"
          >
            <svg id="theme-icon-sun-mobile" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="hidden" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
            </svg>
            <svg id="theme-icon-moon-mobile" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" class="hidden" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/>
            </svg>
          </button>
          <button
            id="mobile-menu-btn"
            aria-label="메뉴 열기"
            class="flex h-9 w-9 flex-col items-center justify-center gap-1.5 rounded-lg border border-[var(--color-border)]"
          >
            <span class="block h-0.5 w-5 bg-[var(--color-text)] transition-all" id="hamburger-line-1"></span>
            <span class="block h-0.5 w-5 bg-[var(--color-text)] transition-all" id="hamburger-line-2"></span>
            <span class="block h-0.5 w-5 bg-[var(--color-text)] transition-all" id="hamburger-line-3"></span>
          </button>
        </div>
      </div>

      <!-- Mobile slide-in menu -->
      <div
        id="mobile-menu"
        class="hidden border-t border-[var(--color-border)] bg-[var(--color-surface)] md:hidden"
      >
        <div class="flex flex-col px-6 py-4 gap-1">
          <a
            href={`${base}`}
            class={`rounded-lg px-3 py-2.5 text-sm transition-colors hover:bg-[var(--color-primary-light)] hover:text-[var(--color-primary)] ${isActive(base) ? 'bg-[var(--color-primary-light)] font-semibold text-[var(--color-primary)]' : 'text-[var(--color-text-muted)]'}`}
          >홈</a>
          <a
            href={`${base}dashboard`}
            class={`rounded-lg px-3 py-2.5 text-sm transition-colors hover:bg-[var(--color-primary-light)] hover:text-[var(--color-primary)] ${isActive(`${base}dashboard`) ? 'bg-[var(--color-primary-light)] font-semibold text-[var(--color-primary)]' : 'text-[var(--color-text-muted)]'}`}
          >대시보드</a>
          <a
            href={`${base}cards`}
            class={`rounded-lg px-3 py-2.5 text-sm transition-colors hover:bg-[var(--color-primary-light)] hover:text-[var(--color-primary)] ${isActive(`${base}cards`) ? 'bg-[var(--color-primary-light)] font-semibold text-[var(--color-primary)]' : 'text-[var(--color-text-muted)]'}`}
          >카드 목록</a>
          <a
            href={`${base}results`}
            class={`rounded-lg px-3 py-2.5 text-sm transition-colors hover:bg-[var(--color-primary-light)] hover:text-[var(--color-primary)] ${isActive(`${base}results`) ? 'bg-[var(--color-primary-light)] font-semibold text-[var(--color-primary)]' : 'text-[var(--color-text-muted)]'}`}
          >최적화 결과</a>
        </div>
      </div>
    </nav>

    <main class="mx-auto max-w-7xl px-6 py-8 animate-[fadeIn_0.3s_ease]">
      <slot />
    </main>

    <footer class="mt-16 border-t border-[var(--color-border)] bg-[var(--color-surface)]">
      <div class="mx-auto max-w-7xl px-6 py-10">
        <div class="flex flex-col items-center gap-6 md:flex-row md:justify-between">
          <div>
            <div class="flex items-center gap-2 text-base font-bold text-[var(--color-primary)]">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z"/>
              </svg>
              CherryPicker
            </div>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">내 소비에 맞는 카드 조합 찾기</p>
          </div>
          <div class="text-center text-sm text-[var(--color-text-muted)]">
            <span class="font-semibold text-[var(--color-text)]">319+</span> 카드 혜택 데이터 수록 &nbsp;·&nbsp;
            <span class="font-semibold text-[var(--color-text)]">20</span>개 카드사 &nbsp;·&nbsp;
            <span class="font-semibold text-[var(--color-text)]">16</span>개 카테고리
          </div>
          <div class="flex gap-4 text-sm text-[var(--color-text-muted)]">
            <a href={`${base}`} class="hover:text-[var(--color-primary)] transition-colors">홈</a>
            <a href={`${base}cards`} class="hover:text-[var(--color-primary)] transition-colors">카드 목록</a>
            <a href={`${base}dashboard`} class="hover:text-[var(--color-primary)] transition-colors">대시보드</a>
          </div>
        </div>
        <div class="mt-6 border-t border-[var(--color-border)] pt-6 text-center text-xs text-[var(--color-text-muted)]">
          © 2026 CherryPicker. 카드 혜택은 변동될 수 있으니 참고용으로 활용해 주세요.
        </div>
      </div>
    </footer>

    <script>
      // Dark mode toggle
      function syncThemeIcons() {
        const isDark = document.documentElement.classList.contains('dark');
        const sunEl = document.getElementById('theme-icon-sun');
        const moonEl = document.getElementById('theme-icon-moon');
        const sunElM = document.getElementById('theme-icon-sun-mobile');
        const moonElM = document.getElementById('theme-icon-moon-mobile');
        if (sunEl) sunEl.classList.toggle('hidden', !isDark);
        if (moonEl) moonEl.classList.toggle('hidden', isDark);
        if (sunElM) sunElM.classList.toggle('hidden', !isDark);
        if (moonElM) moonElM.classList.toggle('hidden', isDark);
      }

      function toggleTheme() {
        const html = document.documentElement;
        const isDark = html.classList.toggle('dark');
        try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch (e) {}
        syncThemeIcons();
      }

      document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
      document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
      syncThemeIcons();

      // Mobile menu
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../app.css";
</style>
